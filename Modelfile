FROM qwen2.5-coder:1.5b

# Expand the context window to 16k tokens so large code chunks fit comfortably
PARAMETER num_ctx 16384

# Lower the temperature to make the model deterministic (less creative, more precise)
PARAMETER temperature 0.0

# Set a strict system prompt to control SLM hallucination
SYSTEM """You are a strict, offline IDE code parsing agent. 
- Answer questions using only the provided code context. 
- Never guess, extrapolate, or invent functions/objects that are not explicitly written.
- If counting items, count only the top-level parent roots and ignore nested schemas."""
